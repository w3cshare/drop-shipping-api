# ======== 通用 ========
# Node 调试
VITE_PORT=5173

# 后端 API 地址（开发态用 proxy 转发，生产态部署在同域或填绝对地址）
VITE_API_BASE_URL=http://localhost:3000

# ======== 应用内模式（Embedded App，Shopify Admin iframe 内） ========
# Shopify Partner Dashboard 分配的 API Key
VITE_SHOPIFY_API_KEY=YOUR_SHOPIFY_API_KEY

# ======== 独立模式（Standalone，商家自有后台系统） ========
# 不需要额外 key，直接用后端的 JWT 登录系统
