# Shopify App Configuration
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here
SHOPIFY_API_VERSION=2026-01
SHOPIFY_HOST=https://your-domain.tunnelfrp.com
SHOPIFY_SCOPES=read_products,write_products,read_orders,write_orders,read_customers,write_customers

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/shopify_app

# Application Configuration
PORT=3000
SESSION_SECRET_KEY=your_session_secret_key_here

# Environment
NODE_ENV=development
